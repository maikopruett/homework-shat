{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "homework-shat",
  "compatibility_date": "2024-11-28",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
  // Add your OPENROUTER_API_KEY as a secret:
  // npx wrangler secret put OPENROUTER_API_KEY
}

